# Ignore everything by default.
*

# Keep repository metadata needed by Git users.
!.gitignore
!README.md
!README.en.md

# Keep the project directories that should be uploaded.
!Bridge/
!Bridge/**
!Docs/
!Docs/**
!Firmware/
!Firmware/**
!Hardware/
!Hardware/**

# Ignore generated PlatformIO and editor files even inside kept directories.
.pio/
.vscode/
**/.pio/
**/.vscode/
Firmware/include/wifi_secrets.h
Bridge/config.local.json
