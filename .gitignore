# Ignore everything by default.
*

# Keep repository metadata needed by Git users.
!.gitignore
!README.md
!README.en.md
!USAGE.md
!USAGE.en.md
!LICENSE

# Keep the project directories that should be uploaded.
!Bridge/
!Bridge/**
!Docs/
!Docs/**
!Firmware/
!Firmware/**
!Hardware/
!Hardware/**

# Ignore generated PlatformIO and editor files even inside kept directories.
.pio/
.vscode/
**/.pio/
**/.pio-codex-build/
**/.vscode/
Firmware/include/wifi_secrets.h
Bridge/config.local.json
Bridge/logs/
Bridge/__pycache__/
**/__pycache__/
*.py[cod]

# Local runtime state and secrets.
*.local.json
*.local.toml
*.local.yaml
*.local.yml
*.log
*.tmp
*.bak
wifi_secrets.h
secrets.h
credentials.*

# Python and Windows local caches.
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.pyo
Thumbs.db
Desktop.ini

# Local diagnostic firmware sketches that are not part of the shipped build.
Firmware/ap_join_test/
